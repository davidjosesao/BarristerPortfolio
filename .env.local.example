# ── Email (Resend) ──────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=briefs@yourdomain.com.au        # must be a verified Resend sender domain
RECIPIENT_EMAIL=barrister@example.com      # barrister's email
CLERK_EMAIL=clerk@example.com              # clerk BCC (omit to disable)

# ── AI Summary (Google Gemini) ──────────────────────────────────
# Free tier — get key at https://aistudio.google.com
GEMINI_API_KEY=AIza...

# ── Supabase ────────────────────────────────────────────────────
# Get these from: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...           # server-only — never expose to browser

# ── Rate limiting (Vercel KV) ───────────────────────────────────
# Added automatically when you link a KV store in the Vercel dashboard
KV_URL=redis://...
KV_REST_API_URL=https://...
KV_REST_API_TOKEN=...
KV_REST_API_READ_ONLY_TOKEN=...

# ── Testing ─────────────────────────────────────────────────────
# When set, ALL outbound emails redirect to this address.
# Blocked automatically when VERCEL_ENV=production.
# ⚠️  Leave blank or remove before going live.
TEST_EMAIL_OVERRIDE=
